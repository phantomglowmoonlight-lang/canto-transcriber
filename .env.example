# ─── 語音識別 ───
# 模型大小: tiny / base / small / medium / large-v2 / large-v3
WHISPER_MODEL_SIZE=large-v3
# 運算設備: auto / cpu / cuda
WHISPER_DEVICE=auto
# 計算精度: int8 / float16 / float32（float16 兼顧記憶體與品質，float32 最準但最耗資源）
WHISPER_COMPUTE_TYPE=float16
# 本機模型路徑（執行 download_models.py 下載後填入此處；留空則首次執行時從 HuggingFace 下載）
WHISPER_MODEL_PATH=

# ─── 粵語→書面語翻譯 ───
# 翻譯模型路徑（執行 download_models.py 下載後填入此處）
TRANSLATION_MODEL_PATH=

# ─── 外部工具 ───
# ffmpeg 路徑（留空自動從 PATH 找；Windows 用戶如未加入 PATH 可設絕對路徑）
FFMPEG_PATH=

# ─── 音頻處理 ───
# 單段最長分鐘數（超過自動切割）
CHUNK_MAX_MINUTES=10
# 切割點前後重疊秒數
CHUNK_OVERLAP_SECONDS=30
# 取樣率（Hz）
SAMPLE_RATE=16000

# ─── 說話人分離 ───
# 模式: auto / pyannote / vad
DIARIZATION_MODE=auto
# HuggingFace Token（pyannote 模式需要）
HF_TOKEN=

# ─── AI 會議報告 ───
# LLM 提供商: ollama / openai / custom
LLM_PROVIDER=ollama
# API 端點（相容 OpenAI 格式）
LLM_API_BASE=http://localhost:11434/v1
# API Key（openai 模式需要）
LLM_API_KEY=
# 模型名稱
LLM_MODEL=gemma3:12b
# 報告語言: zh / yue / en
REPORT_LANGUAGE=zh

# ─── API 服務器 ───
API_HOST=0.0.0.0
API_PORT=8000
